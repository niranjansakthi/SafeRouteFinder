{
  "rewrites": [
    {
      "source": "/predict",
      "destination": "https://saferoutefinder.onrender.com/predict"
    },
    {
      "source": "/health",
      "destination": "https://saferoutefinder.onrender.com/health"
    }
  ],
  "headers": [
    {
      "source": "/predict",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
